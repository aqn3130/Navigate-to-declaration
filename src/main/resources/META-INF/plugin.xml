    <name>Navigate-to-declaration</name>
    <vendor>aqn3130</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.aqn3130.navigatetodeclaration.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
